{
  "schema_version": "matchpulse-competition-gates-v2",
  "project": "MatchPulse",
  "scope": "full_product_competition",
  "status": "review_only_until_merged",
  "autonomy_mode": "aggressive_gated",
  "gate_resolutions": [
    {
      "gate_id": "GATE_DB_LOCAL",
      "canonical": true,
      "status": "approved",
      "activation": "exact phase manifest only",
      "allows": ["repository-managed isolated local or ephemeral PostgreSQL 16", "migration work explicitly allowed by the phase manifest after all safety checks"],
      "requires_when_migration_allowed": ["schema validation", "migration diff", "migration test", "data-integrity verification", "rollback or forward-fix instructions"],
      "forbids": ["shared database mutation", "hosted database mutation", "staging database mutation", "production database mutation", "remote database mutation"]
    },
    {
      "gate_id": "GATE_PUBLIC_SAFE_API",
      "canonical": true,
      "status": "approved",
      "activation": "versioned competition API",
      "requires": ["redaction", "forbidden-field tests", "safe degraded states"],
      "forbids": ["internal weights", "provider payloads", "raw confidence", "credentials", "gambling fields"]
    },
    {
      "gate_id": "GATE_LOCAL_INTEGRATION",
      "canonical": true,
      "status": "approved",
      "activation": "offline fixtures, local fakes and contract tests",
      "requires": ["live external access disabled unless separately authorized"],
      "forbids": ["live external service access", "secret use"]
    },
    {
      "gate_id": "GATE_LOCAL_RELEASE",
      "canonical": true,
      "status": "approved",
      "activation": "phase-declared local quality gates",
      "requires": ["reproducible local deployment", "seeded smoke testing", "security checks", "submission documentation"],
      "forbids": ["remote deployment"]
    }
  ],
  "legacy_gate_aliases": [
    {"legacy_id":"GATE_DB_DEV","canonical_id":"GATE_DB_LOCAL","authoritative":false},
    {"legacy_id":"GATE_PUBLIC_CONTRACT","canonical_id":"GATE_PUBLIC_SAFE_API","authoritative":false},
    {"legacy_id":"GATE_NOTIFICATION","canonical_id":"GATE_LOCAL_INTEGRATION","authoritative":false},
    {"legacy_id":"GATE_DEPLOYMENT","canonical_id":"GATE_LOCAL_RELEASE","authoritative":false},
    {"legacy_id":"GATE_RELEASE","canonical_id":"GATE_LOCAL_RELEASE","authoritative":false},
    {"legacy_id":"GATE_UX_BRAND","canonical_id":null,"authoritative":false,"disposition":"requirements retained in product scope; not a technical activation gate"},
    {"legacy_id":"GATE_TXLINE_REAL","canonical_id":null,"authoritative":false,"disposition":"live access remains disabled and is not required for program completion"},
    {"legacy_id":"GATE_SOLANA","canonical_id":null,"authoritative":false,"disposition":"deferred and not required for program completion"}
  ],
  "auto_publish_policy": {
    "allowed_risk_classes_after_program_enablement": ["R0", "R1", "R2"],
    "R3_code_only_local_changes": "allowed only when covered by an approved canonical gate and the exact phase manifest explicitly permits local-only execution",
    "R4_or_remote_mutation": "not allowed"
  }
}
