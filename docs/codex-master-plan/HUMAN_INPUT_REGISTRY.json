      "category": "release",
      "status": "unresolved",
      "blocking_phases": ["10P"],
      "secret": false,
      "prompt": "Approve release channel, versioning, launch criteria and rollback owner.",
      "required_fields": ["release_type", "versioning_scheme", "required_environments", "smoke_test_owner", "rollback_owner", "launch_window", "demo_or_production", "known_limitations_approval", "release_notes_audience"]
