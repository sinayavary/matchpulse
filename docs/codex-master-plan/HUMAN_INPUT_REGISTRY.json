      "blocking_phases": ["10K"],
      "secret": false,
      "prompt": "Approve the public API audience, authentication, versioning and exposed prediction fields.",
      "required_fields": ["public_or_authenticated", "consumer_types", "versioning_policy", "rate_limit_policy", "exposed_fields", "forbidden_fields", "retention_and_cache_policy", "breaking_change_policy"]
    },
    {
