{
  "schema_version": "matchpulse-human-input-registry-v1",
  "project": "MatchPulse",
  "instructions": {
    "secret_values_in_git": false,
    "secret_delivery": "Use the approved secret store or local environment only. Record variable names and validation status in Git, never values.",
    "unknown_non_blocking_behavior": "Use documented reversible defaults for low-risk implementation details.",
    "unknown_blocking_behavior": "Stop only at the first phase that requires the unresolved input and emit INPUT_REQUIRED with the exact input id."
  },
  "inputs": [
    {
      "id": "product_scope_priority",
      "category": "product",
      "status": "proposed_default",
      "blocking_phases": [],
      "secret": false,
      "prompt": "Confirm the priority order: reliable live intelligence first, public API second, web experience third, notifications fourth, on-chain proof fifth.",
      "default": "Use the order encoded in PROGRAM_PLAN.json.",
      "required_fields": ["approved", "notes"]
    },
    {
      "id": "supported_competitions",
      "category": "product",
      "status": "unresolved",
      "blocking_phases": ["10J-B", "10L", "10P"],
      "secret": false,
      "prompt": "Which football competitions and seasons are required for the first production release?",
      "required_fields": ["competition_ids_or_names", "season_scope", "priority_order", "excluded_competitions"]
    },
    {
      "id": "supported_languages",
      "category": "product",
      "status": "proposed_default",
      "blocking_phases": ["10L", "10M", "10P"],
      "secret": false,
      "prompt": "Which user-facing languages are required?",
      "default": ["fa", "en"],
      "required_fields": ["languages", "default_language", "rtl_required"]
