diff --git a/apps/api/src/competition-model-profile.test.ts b/apps/api/src/competition-model-profile.test.ts
--- a/apps/api/src/competition-model-profile.test.ts
+++ b/apps/api/src/competition-model-profile.test.ts
@@ -179,3 +179,85 @@
     /Usable market evidence requires/,
   );
 });
+
+test("market counterfactual influence stays within the approved model-use cap", () => {
+  const homeMarket = baseInput();
+  homeMarket.market.approved_model_weight_cap = 0.01;
+  homeMarket.market.direction = "neutral";
+  homeMarket.market.next_goal = { home: 1, none: 0, away: 0 };
+
+  const awayMarket = structuredClone(homeMarket);
+  awayMarket.market.next_goal = { home: 0, none: 0, away: 1 };
+
+  const homeSnapshot = buildCompetitionPredictionSnapshot(homeMarket);
+  const awaySnapshot = buildCompetitionPredictionSnapshot(awayMarket);
+  const cap = homeSnapshot.odds_intelligence_reference.assigned_market_weight;
+
+  assert.equal(cap, 0.01);
+  assert.ok(Math.abs(
+    homeSnapshot.model_output.next_goal.home - awaySnapshot.model_output.next_goal.home,
+  ) <= cap + 1e-12);
+  assert.ok(Math.abs(
+    homeSnapshot.model_output.next_goal.away - awaySnapshot.model_output.next_goal.away,
+  ) <= cap + 1e-12);
+});
+
+test("finished probabilities remain terminal while stale incomplete data lowers confidence", () => {
+  const input = baseInput();
+  input.phase = "FT";
+  input.normalized_phase = "finished";
+  input.minute = null;
+  input.home_score = 2;
+  input.away_score = 1;
+  input.freshness_score = 0;
+  input.market = {
+    available: false,
+    usable_for_model: false,
+    assessment_id: null,
+    reliability_score: 0,
+    approved_model_weight_cap: 0,
+    final_outcome: null,
+    next_goal: null,
+    direction: "unknown",
+    limitations: ["Internal market limitation."],
+  };
+  input.events = {
+    available: false,
+    home_pressure: 0,
+    away_pressure: 0,
+    home_impact: 0,
+    away_impact: 0,
+    limitations: ["Internal event limitation."],
+  };
+
+  const snapshot = buildCompetitionPredictionSnapshot(input);
+
+  assert.deepEqual(snapshot.model_output.final_outcome, { home: 1, draw: 0, away: 0 });
+  assert.equal(snapshot.confidence.level, "very_low");
+  assert.equal(snapshot.risk.level, "high");
+  assert.equal(snapshot.risk.reasons.includes("stale_data"), true);
+  assert.equal(snapshot.risk.reasons.includes("missing_minute"), true);
+  assert.equal(snapshot.risk.reasons.includes("missing_odds"), true);
+  assert.equal(snapshot.risk.reasons.includes("missing_events"), true);
+});
+
+test("public-shaped explanation does not copy caller limitation text verbatim", () => {
+  const input = baseInput();
+  input.market.limitations = ["ProviderAlpha formula threshold is private."];
+  input.events.limitations = ["Secret event weight is private."];
+
+  const snapshot = buildCompetitionPredictionSnapshot(input);
+  const explanationText = snapshot.explanation.limitations.join(" ");
+
+  assert.equal(explanationText.includes("ProviderAlpha"), false);
+  assert.equal(explanationText.includes("formula threshold"), false);
+  assert.equal(explanationText.includes("Secret event weight"), false);
+  assert.equal(
+    snapshot.explanation.limitations.includes("Market evidence has internal limitations."),
+    true,
+  );
+  assert.equal(
+    snapshot.explanation.limitations.includes("Event evidence has internal limitations."),
+    true,
+  );
+});
diff --git a/docs/phase-comp-a-competition-prediction-baseline.md b/docs/phase-comp-a-competition-prediction-baseline.md
--- a/docs/phase-comp-a-competition-prediction-baseline.md
