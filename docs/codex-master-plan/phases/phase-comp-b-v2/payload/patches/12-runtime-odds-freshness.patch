+function runtimeOddsFreshness(
+  context: InternalOddsIntelligenceContext,
+  generatedAt: string,
+): { score: number; last_update: string | null } {
+  const generatedAtMs = Date.parse(generatedAt);
+  const latest = context.markets
+    .map((market) => market.latest_timestamp)
+    .filter((value): value is string => value !== null)
+    .map((value) => Date.parse(value))
+    .filter((value) => Number.isFinite(value) && value <= generatedAtMs)
+    .sort((left, right) => right - left)[0];
+  if (latest === undefined) return { score: 0, last_update: null };
+  const lastUpdate = new Date(latest).toISOString();
+  return { score: freshnessScore(lastUpdate, generatedAt), last_update: lastUpdate };
+}
