{
  "schema_version": "matchpulse-program-plan-v1",
  "project": "MatchPulse",
  "program_id": "matchpulse-production-completion-v1",
  "program_mode": {
    "enabled": false,
    "requires_human_enablement": true,
    "auto_select_next_phase": true,
    "auto_prepare_low_risk_phases": true,
    "auto_publish_low_risk_phases": false,
    "max_parallel_phases": 1,
    "stop_on_high_or_critical_security_finding": true,
    "stop_on_unresolved_p0_or_p1": true
  },
  "authority_order": [
    "AGENTS.md",
    "docs/codex-master-plan/EXECUTION_PROTOCOL.md",
    "docs/codex-master-plan/ACTIVE_PHASE.json",
    "docs/codex-master-plan/PROGRAM_PLAN.json",
    "active phase manifest",
    "docs/codex-master-plan/AUTONOMOUS_EXECUTION_CONTRACT.md",
    "docs/codex-master-plan/PROGRAM_GOAL.md"
  ],
  "default_policies": {
    "network_access": false,
    "migration_allowed": false,
    "production_mutation": false,
    "force_push": false,
    "secret_values_in_git": false,
    "public_provider_details": false,
    "private_policy_values_in_git": false,
    "unbounded_retry": false,
    "unbounded_concurrency": false,
    "test_weakening": false,
    "success_requires_evidence": true
  },
  "risk_classes": {
    "R0": "documentation or read-only analysis",
    "R1": "reversible source and test changes without network, migration, public contract, or security-boundary change",
    "R2": "internal integration or persistence code prepared without applying a migration or accessing a real service",
    "R3": "public contract, schema, authentication, notification, real network, paid resource, or data mutation",
    "R4": "production deployment, release, secret rotation, or irreversible operation"
  },
  "gates": [
    {
      "id": "GATE_DB_DEV",
      "description": "Approved development database, connection method, backup, migration and rollback authority",
      "required_input_ids": ["database_development", "migration_authority"],
      "hard": true
    },
    {
      "id": "GATE_PUBLIC_CONTRACT",
      "description": "Approval of the versioned public API and exposed fields",
      "required_input_ids": ["public_api_policy"],
      "hard": true
    },
    {
      "id": "GATE_UX_BRAND",
      "description": "Approval of product identity, design direction, supported languages and accessibility target",
      "required_input_ids": ["brand_and_ux"],
      "hard": true
    },
    {
      "id": "GATE_NOTIFICATION",
      "description": "Approval and credentials for user-controlled notification channels",
      "required_input_ids": ["notification_policy", "telegram_environment"],
      "hard": true
    },
    {
      "id": "GATE_TXLINE_REAL",
      "description": "Approval and credentials for real TxLINE environment access and quotas",
      "required_input_ids": ["txline_environment"],
      "hard": true
    },
    {
      "id": "GATE_SOLANA",
      "description": "Approval of Solana cluster, wallet authority, program identifiers and spending policy",
      "required_input_ids": ["solana_environment"],
      "hard": true
    },
    {
      "id": "GATE_DEPLOYMENT",
      "description": "Approved hosting, DNS, TLS, observability, secret store and deployment authority",
      "required_input_ids": ["hosting_and_deployment", "domain_and_dns", "observability_environment"],
      "hard": true
    },
    {
      "id": "GATE_RELEASE",
      "description": "Approval of exact release commit, environment, known limitations and rollback plan",
      "required_input_ids": ["release_policy"],
      "hard": true
    }
  ],
