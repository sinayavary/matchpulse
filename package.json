{
  "name": "matchpulse-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "pnpm --filter @matchpulse/web dev",
    "dev:api": "pnpm --filter @matchpulse/api dev",
    "dev:worker": "pnpm --filter @matchpulse/worker dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:seed": "pnpm --filter @matchpulse/api prisma:seed",
    "prisma:studio": "prisma studio"
  },
  "devDependencies": {
    "@prisma/client": "^6.0.1",
    "@types/node": "^22.10.2",
    "prisma": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
