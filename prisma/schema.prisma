generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Fixture {
  id           String    @id @default(uuid()) @db.Uuid
  fixtureId    String    @unique @map("fixture_id")
  competition  String
  stage        String?
  sport        String    @default("soccer")
  startTimeUtc DateTime? @map("start_time_utc") @db.Timestamptz(3)
  homeTeam     String    @map("home_team")
  awayTeam     String    @map("away_team")
  status       String    @default("UNKNOWN")
  raw          Json?
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  matchState     MatchState?
  matchEvents    MatchEvent[]
  replaySessions ReplaySession[]

  @@index([startTimeUtc])
  @@index([status])
  @@map("fixtures")
}

model MatchState {
  id                 String    @id @default(uuid()) @db.Uuid
  fixtureId          String    @unique @map("fixture_id")
  minute             Int?
  phase              String    @default("unknown")
  homeScore          Int?      @map("home_score")
  awayScore          Int?      @map("away_score")
  inRunning          Boolean?  @map("in_running")
  marketMood         String    @default("unknown") @map("market_mood")
  momentumSide       String    @default("unknown") @map("momentum_side")
  momentumScore      Decimal?  @map("momentum_score") @db.Decimal(5, 2)
  rawScore           Json?     @map("raw_score")
  rawOdds            Json?     @map("raw_odds")
  lastDataReceivedAt DateTime? @map("last_data_received_at") @db.Timestamptz(3)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  fixture Fixture @relation(fields: [fixtureId], references: [fixtureId], onDelete: Cascade)

  @@index([phase])
  @@index([lastDataReceivedAt])
  @@map("match_states")
}

model MatchEvent {
  id              String    @id @default(uuid()) @db.Uuid
  fixtureId       String    @map("fixture_id")
  externalSeq     String?   @map("external_seq")
  eventType       String    @map("event_type")
  eventMinute     Int?      @map("event_minute")
  teamSide        String    @default("unknown") @map("team_side")
  title           String
  description     String?
  sourceTimestamp DateTime? @map("source_timestamp") @db.Timestamptz(3)
  raw             Json?
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  fixture Fixture @relation(fields: [fixtureId], references: [fixtureId], onDelete: Cascade)

  @@unique([fixtureId, externalSeq])
  @@index([fixtureId, sourceTimestamp])
  @@index([eventType])
  @@map("match_events")
}

model OddsSnapshot {
  id              String    @id @default(uuid()) @db.Uuid
  fixtureId       String    @map("fixture_id")
  externalSeq     String?   @map("external_seq")
  marketId        String    @map("market_id")
  marketName      String?   @map("market_name")
  selectionName   String    @map("selection_name")
  odds            Decimal   @db.Decimal(12, 4)
  previousOdds    Decimal?  @map("previous_odds") @db.Decimal(12, 4)
  changePercent   Decimal?  @map("change_percent") @db.Decimal(12, 4)
  direction       String
  sourceTimestamp DateTime? @map("source_timestamp") @db.Timestamptz(3)
  raw             Json?
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  @@unique([fixtureId, externalSeq, marketId, selectionName])
  @@index([fixtureId, sourceTimestamp])
  @@index([marketId])
  @@map("odds_snapshots")
}

model Signal {
  id                 String   @id @default(uuid()) @db.Uuid
  fixtureId          String   @map("fixture_id")
  relatedEventId     String?  @map("related_event_id") @db.Uuid
  signalType         String   @map("signal_type")
  title              String
  severity           String
  confidence         Decimal  @db.Decimal(5, 4)
  riskLevel          String   @map("risk_level")
  eventMinute        Int?     @map("event_minute")
  explanation        String
  technicalReasoning Json?    @map("technical_reasoning")
  rawInputs          Json?    @map("raw_inputs")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([fixtureId, createdAt])
  @@index([signalType])
  @@index([severity])
  @@index([riskLevel])
  @@map("signals")
}

model Scenario {
  id                  String   @id @default(uuid()) @db.Uuid
  fixtureId           String   @map("fixture_id")
  signalId            String?  @map("signal_id") @db.Uuid
  scenarioName        String   @map("scenario_name")
  probability         Decimal  @db.Decimal(5, 4)
  previousProbability Decimal? @map("previous_probability") @db.Decimal(5, 4)
  direction           String
  confidence          Decimal  @db.Decimal(5, 4)
  explanation         String
  inputs              Json?
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([fixtureId, createdAt])
  @@index([scenarioName])
  @@map("scenarios")
}

model ReplaySession {
  id            String    @id @default(uuid()) @db.Uuid
  sessionId     String    @unique @map("session_id")
  fixtureId     String    @map("fixture_id")
  status        String    @default("running")
  speed         Int       @default(1)
  currentMinute Int?      @map("current_minute")
  startedAt     DateTime? @map("started_at") @db.Timestamptz(3)
  stoppedAt     DateTime? @map("stopped_at") @db.Timestamptz(3)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  fixture Fixture @relation(fields: [fixtureId], references: [fixtureId], onDelete: Cascade)

  @@index([fixtureId])
  @@map("replay_sessions")
}

model HealthStatus {
  id                 String    @id @default(uuid()) @db.Uuid
  serviceName        String    @unique @map("service_name")
  status             String
  lastHeartbeat      DateTime? @map("last_heartbeat") @db.Timestamptz(3)
  lastDataReceivedAt DateTime? @map("last_data_received_at") @db.Timestamptz(3)
  errorCount         Int       @default(0) @map("error_count")
  lastError          String?   @map("last_error")
  raw                Json?
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([status])
  @@map("health_status")
}
