# Shared
NODE_ENV=development

# API
API_PORT=4000
CORS_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/matchpulse?schema=public

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=MatchPulse

# TxLINE — devnet first
TXLINE_NETWORK=devnet
TXLINE_SERVICE_LEVEL_ID=1
TXLINE_API_ORIGIN=https://txline-dev.txodds.com
TXLINE_API_BASE_URL=https://txline-dev.txodds.com/api
TXLINE_GUEST_AUTH_URL=https://txline-dev.txodds.com/auth/guest/start
TXLINE_RPC_URL=https://api.devnet.solana.com

# TxLINE — secrets (never commit real values)
TXLINE_GUEST_JWT=
TXLINE_API_TOKEN=

# Solana devnet keypair (path relative to repo root, inside gitignored secrets/)
SOLANA_KEYPAIR_PATH=./secrets/matchpulse-dev-wallet.json

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
